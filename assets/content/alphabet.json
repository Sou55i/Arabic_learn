        { "type": "mcq", "prompt_fr": "Comment distinguer ت de ث ?", "options": ["ت a 2 points, ث en a 3", "ت a 3 points, ث en a 2", "ت a 1 point, ث en a 2", "Ils sont identiques"], "answer": "ت a 2 points, ث en a 3" },
